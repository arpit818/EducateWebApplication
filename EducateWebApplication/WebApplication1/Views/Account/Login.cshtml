@{
    ViewData["Title"] = "Login";
    Layout = "_BlankLayout";
}

<div class="login-page">
    <div class="login-left">
        <div class="illustration">
            <div class="icon-circle">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div class="floating-icon icon1">f(x)</div>
            <div class="floating-icon icon2">π</div>
            <div class="floating-icon icon3">√x</div>
        </div>
        <h2>Exam Mastery Hub</h2>
        <p>Unleash Your Academic Success with Exam Mastery Hub's Exam Excellence Platform</p>
        <div class="dots">
            <span></span><span class="active"></span><span></span><span></span>
        </div>
    </div>

    <div class="login-right">
        <div class="login-form-container">
            <div class="brand">
                <i class="bi bi-mortarboard-fill"></i>
                <span>MASTERY <strong>HUB</strong></span>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                <div class="form-group-custom">
                    <label>Username or email</label>
                    <input type="text" name="username" placeholder="" required />
                </div>

                <div class="form-group-custom">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="" required />
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn-signin">Sign in</button>
            </form>

            <div class="divider"><span>or</span></div>

            <button class="btn-google">
                <i class="bi bi-google"></i> Sign in with Google
            </button>

            <p class="register-text">
                Are you new? <a asp-controller="Account" asp-action="Register">Create an Account</a>
            </p>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["ErrorMessage"] != null)
{
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Oops...',
            text: '@TempData["ErrorMessage"]',
            confirmButtonColor: '#2f6e51'
        });
    </script>
}

@if (TempData["SuccessMessage"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Success',
            text: '@TempData["SuccessMessage"]',
            confirmButtonColor: '#2f6e51'
        });
    </script>
}